# ENVIRONMENT CONFIGURATION TEMPLATE
# Create .env file in the root directory with these values

# ─────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ─────────────────────────────────────────────────────────

DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=appdb
DB_USER=admin
DB_PASSWORD=YOUR_GENERATED_SECURE_PASSWORD

# ─────────────────────────────────────────────────────────
# AWS CONFIGURATION
# ─────────────────────────────────────────────────────────

AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=396287094911

# SQS (Queue Service - replaces Kafka)
AWS_SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/396287094911/scrapninja-events
AWS_SQS_QUEUE_NAME=scrapninja-events

# S3 (Static Storage & Uploads)
AWS_S3_BUCKET=scrapninja-static-396287094911
AWS_S3_REGION=ap-south-1

# RDS Endpoint
RDS_ENDPOINT=your-db-instance.c9akciq32.rds.ap-south-1.amazonaws.com

# ─────────────────────────────────────────────────────────
# REDIS CONFIGURATION
# ─────────────────────────────────────────────────────────

REDIS_HOST=your-redis-private-ip
REDIS_PORT=6379
REDIS_PASSWORD=

# For local development:
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ─────────────────────────────────────────────────────────
# APPLICATION CONFIGURATION
# ─────────────────────────────────────────────────────────

APP_ENV=production
APP_DEBUG=false
APP_PORT=8080

# CORS Configuration
CORS_ORIGIN=https://scrapninja.com,https://www.scrapninja.com,https://api.scrapninja.com

# ─────────────────────────────────────────────────────────
# SERVICE ENDPOINTS
# ─────────────────────────────────────────────────────────

AUTH_SERVICE_URL=http://auth-service:8080
API_GATEWAY_URL=http://api-gateway:9000
ENQUIRY_SERVICE_URL=http://enquiry-service:8081
PICKUP_SERVICE_URL=http://pickup-service:8082
PRICING_SERVICE_URL=http://pricing-service:8083
LOCATION_SERVICE_URL=http://location-service:8084
VENDOR_SERVICE_URL=http://vendor-onboarding-service:8085

# ─────────────────────────────────────────────────────────
# EXTERNAL INTEGRATIONS
# ─────────────────────────────────────────────────────────

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# SMS Service (Optional)
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=ScrapNinja

# Payment Gateway (Optional)
PAYMENT_GATEWAY_KEY=your-payment-key
PAYMENT_GATEWAY_SECRET=your-payment-secret

# ─────────────────────────────────────────────────────────
# LOGGING & MONITORING
# ─────────────────────────────────────────────────────────

LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=/var/log/scrapninja.log

# CloudWatch
ENABLE_CLOUDWATCH=true
CLOUDWATCH_NAMESPACE=ScrapNinja

# ─────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────

JWT_SECRET=your-jwt-secret-key-min-32-chars
JWT_EXPIRATION=7d

API_KEY=your-api-key-for-internal-services

# SSL Configuration (for local testing)
# SSL_CERT=/path/to/cert.pem
# SSL_KEY=/path/to/key.pem

# ─────────────────────────────────────────────────────────
# FEATURE FLAGS
# ─────────────────────────────────────────────────────────

ENABLE_ANALYTICS=true
ENABLE_NOTIFICATIONS=true
ENABLE_MOBILE_APP=true
ENABLE_VENDOR_DASHBOARD=true

# ─────────────────────────────────────────────────────────
# OPTIMIZATION
# ─────────────────────────────────────────────────────────

# Connection pooling
DB_POOL_MIN=5
DB_POOL_MAX=20

# Cache TTL (in seconds)
CACHE_TTL=3600

# Request timeout
REQUEST_TIMEOUT=30000

# ─────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT ONLY
# ─────────────────────────────────────────────────────────

DOCKER_COMPOSE_PROFILE=local

# Use "local" for local PostgreSQL + Redis
# Use "dev" for development environment
# Use "prod" for production (uses AWS managed services)
